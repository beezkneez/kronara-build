# Kronara Demo — Environment Variables
# Copy this to .env or set these in your Railway deployment

# Database
DATABASE_URL=postgresql://...

# Brand
BRAND_NAME=Kronara
BRAND_SUB=Time. Teams. Simplified.
BRAND_SITE=https://kronara.app
BRAND_LOGO_URL=/logo.png
BRAND_COLOR_PRIMARY=#6C5CE7
BRAND_COLOR_ACCENT=#E8832A
BRAND_COLOR_DARK_BG=#0A0A1A
BRAND_DEFAULT_THEME=kronara

# Demo Mode
DEMO_MODE=true

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=Kronara <support@kronara.app>

# App Domain
APP_DOMAIN=kronara.app
